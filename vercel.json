{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "conditions": [
        {
          "type": "header",
          "key": "Accept",
          "value": "text/html"
        }
      ]
    }
  ]
}
